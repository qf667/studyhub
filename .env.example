# StudyHub 环境变量配置

# 服务器
PORT=3000
NODE_ENV=production

# JWT密钥（生产环境请修改为随机字符串）
JWT_SECRET=your_random_secret_key_here

# CORS允许的源（生产环境填前端域名）
CORS_ORIGIN=*

# AI API配置（可选，不配置则使用模拟数据）
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo

# 数据库（当前使用SQLite，如需MySQL取消注释）
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=studyhub
